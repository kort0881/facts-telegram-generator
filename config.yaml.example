# AI Configuration
# Copy this file to config.yaml and fill in your actual values

ai:
  url: "https://api.groq.com/openai/v1/chat/completions"  # or your AI endpoint
  api_key: "YOUR_API_KEY_HERE"  # Get from your AI provider (free at console.groq.com)
  model: "llama-3.1-70b-versatile"  # Current Groq model (see console.groq.com/docs/models)
  max_tokens: 900

# Telegram Bot (optional for CI/CD - use GitHub Secrets instead)
# telegram:
#   bot_token: "YOUR_BOT_TOKEN_HERE"
#   chat_id: "YOUR_CHAT_ID_HERE"

# Output settings
output:
  directory: "output/posts"
  format: "markdown"  # markdown or json

# Logging
logging:
  level: "INFO"
  file: "facts_generator.log"

# Topic rotation (automatically updated by script)
current_topic_index: 0  # 0=habits, 1=memory, 2=history, 3=laws
